# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/ecommerce

# JWT
JWT_SECRET=ecommerce-super-secret-jwt-key-2024
JWT_EXPIRES_IN=7d

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=demo@example.com
EMAIL_PASS=demo-password

# Payment Gateways
STRIPE_SECRET_KEY=sk_test_demo_key
STRIPE_PUBLISHABLE_KEY=pk_test_demo_key
RAZORPAY_KEY_ID=demo_razorpay_key
RAZORPAY_KEY_SECRET=demo_razorpay_secret

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100